{
  "extends": [
    "config:base",
    ":gitSignOff",
    ":disableDependencyDashboard"
  ],
  "ignorePaths": [
    ".github/**"
  ],
  "labels": [
    "dependency"
  ],
  "separateMinorPatch": true,
  "postUpgradeTasks": {
    "commands": [
      "make gen-golden-all"
    ],
    "fileFilters": [
      "tests/golden/**"
    ],
    "executionMode": "update"
  },
  "suppressNotifications": [
    "artifactErrors"
  ],
  "packageRules": [],
  "registryAliases": {
    "dockerhub.vshn.net": "docker.io"
  }
}
